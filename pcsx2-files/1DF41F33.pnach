// ======== 07-dungeon-speed ========
// Dungeon speed multiplier: scales velocity before CollisionCheck
// Python patches the lui at 0x21F70780 to change the multiplier.
// Default: lui v0, 0x3F80 (1.0 = no change)
//
// Hook CollisionCheck call in RunScript
patch=1,EE,20171438,extended,0C7DC1E0 // jal cave 0x01F70780
// === Code cave at 0x01F70780 ===
// Load multiplier via lui+mtc1 (Python patches the lui immediate)
patch=1,EE,21F70780,extended,3C023F80 // lui v0, 0x3F80  (1.0 default, patched by Python)
patch=1,EE,21F70784,extended,44820000 // mtc1 v0, f0
// Scale vx
patch=1,EE,21F70788,extended,C4C10000 // lwc1 f1, 0(a2)
patch=1,EE,21F7078C,extended,46000842 // mul.S f1, f1, f0
patch=1,EE,21F70790,extended,E4C10000 // swc1 f1, 0(a2)
// Scale vz
patch=1,EE,21F70794,extended,C4C10008 // lwc1 f1, 8(a2)
patch=1,EE,21F70798,extended,46000842 // mul.S f1, f1, f0
patch=1,EE,21F7079C,extended,E4C10008 // swc1 f1, 8(a2)
// Tail-call CollisionCheck
patch=1,EE,21F707A0,extended,0805B11C // j CollisionCheck
patch=1,EE,21F707A4,extended,00000000 // nop

// ======== 09-auto-repair ========
// Auto Repair Powder — intercepts weapon break to auto-consume repair powder
// AUTO_REPAIR_FLAG  (0x01F70048): 1=enabled, set by Python (NOT by PNACH — no init here)
// REPAIR_CONSUMED   (0x01F7004C): written by cave: 1=melee consumed, 2=ranged consumed
//
// Hooks jal AddAbsRate in calcWeaponParamWhp (melee) and calcWeaponParam2 (ranged).
// Cave at 0x01F70B00
// === Hooks: replace jal AddAbsRate in both functions ===
patch=1,EE,201E87B4,extended,0C7DC2C0 // melee: jal cave (was jal AddAbsRate)
patch=1,EE,201E8948,extended,0C7DC2C0 // ranged: jal cave (was jal AddAbsRate)
// === Code cave at 0x01F70B00 ===
// Entry: a0=battleCharaInfo, a1=slot, a2=0, f12=rate, ra=return addr
//
// We must NOT clobber a0/a1/a2/f12 before potentially calling AddAbsRate.
// Use at (r1) for flag check since it's the assembler temp register.
// 0x00: lui at, 0x01F7
patch=1,EE,21F70B00,extended,3C0101F7
// 0x04: lw at, 0x0048(at)  → at = AUTO_REPAIR_FLAG
patch=1,EE,21F70B04,extended,8C210048
// 0x08: bne at, zero, repair (offset=4 → delay@0x0C + 4*4 = 0x1C)
patch=1,EE,21F70B08,extended,14200004
// 0x0C: nop (delay)
patch=1,EE,21F70B0C,extended,00000000
// --- Flag not set: call original AddAbsRate, return ---
// 0x10: j AddAbsRate (0x0019FEE0)  — tail call, reuses our ra
patch=1,EE,21F70B10,extended,08067FB8
// 0x14: nop (delay)
patch=1,EE,21F70B14,extended,00000000
// --- padding ---
// 0x18: nop
patch=1,EE,21F70B18,extended,00000000
// --- repair: (0x1C) restore WHP to max, signal Python, skip AddAbsRate ---
// Save ra and a1
// 0x1C: addiu sp, sp, -16
patch=1,EE,21F70B1C,extended,27BDFFF0
// 0x20: sw ra, 12(sp)
patch=1,EE,21F70B20,extended,AFBF000C
// 0x24: sw a1, 8(sp)
patch=1,EE,21F70B24,extended,AFA50008
// a0=battleCharaInfo, a1=slot — call GetNowAccessWHp
// 0x28: jal GetNowAccessWHp (0x0019F890)
patch=1,EE,21F70B28,extended,0C067E24
// 0x2C: nop (delay)
patch=1,EE,21F70B2C,extended,00000000
// v0 = COMMON_GAGE ptr. If null, skip.
// 0x30: beq v0, zero, done (offset=5 → delay@0x34 + 5*4 = 0x48)
patch=1,EE,21F70B30,extended,10400005
// 0x34: nop (delay)
patch=1,EE,21F70B34,extended,00000000
// Write current = max
// 0x38: lwc1 f0, 0(v0)   ; f0 = max
patch=1,EE,21F70B38,extended,C4400000
// 0x3C: swc1 f0, 4(v0)   ; current = max
patch=1,EE,21F70B3C,extended,E4400004
// REPAIR_CONSUMED = slot + 1
// 0x40: lw a1, 8(sp)
patch=1,EE,21F70B40,extended,8FA50008
// 0x44: addiu a1, a1, 1
patch=1,EE,21F70B44,extended,24A50001
// 0x48: lui at, 0x01F7
patch=1,EE,21F70B48,extended,3C0101F7
// 0x4C: sw a1, 0x004C(at)
patch=1,EE,21F70B4C,extended,AC25004C
// done: restore and return (AddAbsRate skipped)
// 0x50: lw ra, 12(sp)
patch=1,EE,21F70B50,extended,8FBF000C
// 0x54: jr ra
patch=1,EE,21F70B54,extended,03E00008
// 0x58: addiu sp, sp, 16 (delay)
patch=1,EE,21F70B58,extended,27BD0010

// ======== 10-cursor-fix ========
// Hook after SetWakuWH to fix cursor + rect position + rect size
// Hooks GetEtcTblValue call at 0x002C1F48 (runs after SetWakuWH)
// Python writes to 0x01F70B60-0x01F70B78
// Hook
patch=1,EE,202C1F48,extended,0C7DC2E0
// === Cave at 0x01F70B80 ===
patch=1,EE,21F70B80,extended,27BDFFE0 // addiu sp, -32
patch=1,EE,21F70B84,extended,AFBF0000 // sw ra, 0(sp)
// Call original GetEtcTblValue — a0-a3 set by caller + delay slot
patch=1,EE,21F70B88,extended,0C08AAEC // jal GetEtcTblValue (0x0022ABB0)
patch=1,EE,21F70B8C,extended,00000000 // nop
// Check flag
patch=1,EE,21F70B90,extended,3C0201F7 // lui v0, 0x01F7
patch=1,EE,21F70B94,extended,8C430B60 // lw v1, 0x0B60(v0) — cursor X (0=skip)
// beq v1, zero, epilogue (0xBDC). offset=(BDC-B9C)/4=16
patch=1,EE,21F70B98,extended,10600010
patch=1,EE,21F70B9C,extended,00000000 // nop
// Load targets
patch=1,EE,21F70BA0,extended,8C440B64 // cursor Y
patch=1,EE,21F70BA4,extended,8C450B68 // rect X
patch=1,EE,21F70BA8,extended,8C460B6C // rect Y
patch=1,EE,21F70BAC,extended,8C470B70 // rect part addr
patch=1,EE,21F70BB0,extended,8C480B74 // rect width
patch=1,EE,21F70BB4,extended,8C490B78 // rect height
// Load MenuCommonInfo
patch=1,EE,21F70BB8,extended,8F8294F8 // lw v0, -0x6B08(gp)
// Load form pointers
patch=1,EE,21F70BBC,extended,8C4A0138 // lw t2, 0x138(v0) — cursor form
patch=1,EE,21F70BC0,extended,8C4B013C // lw t3, 0x13C(v0) — rect form
// Write cursor pos
patch=1,EE,21F70BC4,extended,AD43000C // sw v1, 0x0C(t2)
patch=1,EE,21F70BC8,extended,AD440010 // sw a0, 0x10(t2)
// Write rect pos
patch=1,EE,21F70BCC,extended,AD65000C // sw a1, 0x0C(t3)
patch=1,EE,21F70BD0,extended,AD660010 // sw a2, 0x10(t3)
// Write rect part size
patch=1,EE,21F70BD4,extended,ACE80024 // sw t0, 0x24(a3) — width
patch=1,EE,21F70BD8,extended,ACE90028 // sw t1, 0x28(a3) — height
// Epilogue (0xBDC)
patch=1,EE,21F70BDC,extended,8FBF0000 // lw ra, 0(sp)
patch=1,EE,21F70BE0,extended,03E00008 // jr ra
patch=1,EE,21F70BE4,extended,27BD0020 // addiu sp, 32

// ======== 11-option-labels ========
// Options screen draw hook — renders custom option labels via CFont
// Label data at 0x01F80000+
