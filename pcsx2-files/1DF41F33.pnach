// ======== 16-render-dispatch ========
// Render Dispatcher — single hook that calls all render subsystems
//
// Hooks DngMainDraw call at 0x001CEB70.
// Calls DngMainDraw, checks visibility, then calls each renderer.
//
// Renderers (jal-callable, each checks own flag, saves/restores own regs):
//   0x01F70748: HUD overlay (dungeon medal/kill info)
//   0x01F71048: Synth HUD (synthesis points on weapon icons)
//   0x01F710C0: Idea HUD (camera idea detection, right side)
//
// IDEA_TEXT buffer: 0x01F711A0 (256 bytes ASCII, written by Python)
//
// Dispatcher at 0x01F71060.
// Town dispatcher at 0x01F712A0.
// === Hook ===
patch=1,EE,201CEB70,extended,0C7DC418 // jal 0x01F71060
// === Dispatcher (0x01F71060) ===
patch=1,EE,21F71060,extended,27BDFFF0 // addiu sp,sp,-16
patch=1,EE,21F71064,extended,AFBF000C // sw ra,12(sp)
patch=1,EE,21F71068,extended,0C073C24 // jal DngMainDraw (0x001CF090)
patch=1,EE,21F7106C,extended,00000000 // nop
patch=1,EE,21F71070,extended,8F828DB0 // lw v0,-0x7250(gp) — BattleAreaScene
patch=1,EE,21F71074,extended,10400006 // beq v0,zero,do_draw (+6 → 0x01F71090)
patch=1,EE,21F71078,extended,00000000 // nop
patch=1,EE,21F7107C,extended,8C42004C // lw v0,0x4C(v0)
patch=1,EE,21F71080,extended,3C013F80 // lui at,0x3F80 (1.0f)
patch=1,EE,21F71084,extended,0041082A // slt at,v0,at
patch=1,EE,21F71088,extended,14200007 // bne at,zero,epilogue (+7 → 0x01F710A8)
patch=1,EE,21F7108C,extended,00000000 // nop
// do_draw:
patch=1,EE,21F71090,extended,0C7DC1D2 // jal HUD overlay (0x01F70748)
patch=1,EE,21F71094,extended,00000000 // nop
patch=1,EE,21F71098,extended,0C7DC412 // jal Synth HUD (0x01F71048)
patch=1,EE,21F7109C,extended,00000000 // nop
patch=1,EE,21F710A0,extended,0C7DC430 // jal Idea HUD (0x01F710C0)
patch=1,EE,21F710A4,extended,00000000 // nop
// epilogue:
patch=1,EE,21F710A8,extended,8FBF000C // lw ra,12(sp)
patch=1,EE,21F710AC,extended,03E00008 // jr ra
patch=1,EE,21F710B0,extended,27BD0010 // addiu sp,sp,16
