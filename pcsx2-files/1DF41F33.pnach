// ======== 13-synth-hud ========
// Synthesis points HUD — draws pending synth points on weapon icons
// Python writes ASCII strings to 0x01F70058 (melee) and 0x01F70068 (ranged)
//
// Chains: this cave -> HUD overlay cave (0x01F70600) -> DngMainDraw
// Checks HUD_FLAG AND anim float >= 1.0 before drawing
// Cave at 0x01F70F50
// Hook: managed by 16-render-dispatch.pnach
// patch=1,EE,201CEB70,extended,0C7DC3D4 // (DISABLED — dispatcher handles this)
// Render-only entry at 0x01F71048: callable via jal, checks own flag, draws, returns.
// Skips chaining to HUD overlay and DngMainDraw.
patch=1,EE,21F71048,extended,27BDFFD0 // addiu sp, -48
patch=1,EE,21F7104C,extended,AFBF0000 // sw ra, 0(sp)
patch=1,EE,21F71050,extended,AFB00004 // sw s0, 4(sp)
// Jump into flag check at 0x01F70F64 (skips chain call)
patch=1,EE,21F71054,extended,087DC3D9 // j 0x01F70F64
patch=1,EE,21F71058,extended,00000000 // nop
// D14 check HUD_FLAG
patch=1,EE,21F70F64,extended,3C0201F7 // lui v0, 0x01F7
patch=1,EE,21F70F68,extended,8C420040 // lw v0, 0x0040(v0)
// D1C beq v0,zero -> epilogue @1038; off=(1038-F70)/4=0x32
patch=1,EE,21F70F6C,extended,10400032 // beq v0, zero, 1038
patch=1,EE,21F70F70,extended,00000000 // nop
// D24 check anim float >= 1.0 (with null check for BattleAreaScene)
patch=1,EE,21F70F74,extended,8F828DB0 // lw v0, -0x7250(gp)
patch=1,EE,21F70F78,extended,10400005 // beq v0, zero, F90 (null → skip anim, draw anyway)
patch=1,EE,21F70F7C,extended,00000000 // nop
patch=1,EE,21F70F80,extended,8C42004C // lw v0, 0x4C(v0)     ; anim float
// compare v0 < 1.0f; bne → epilogue with s0=CFont in delay
patch=1,EE,21F70F84,extended,3C013F80 // lui at, 0x3F80
patch=1,EE,21F70F88,extended,0041082A // slt at, v0, at
// bne at,zero -> epilogue @1038; off=(1038-F90)/4=0x2A
patch=1,EE,21F70F8C,extended,1420002A // bne at, zero, 1038
patch=1,EE,21F70F90,extended,3C10003E // lui s0, 0x003E  (delay: s0=CFont hi)
// D44 s0=CFont lo + SetDrawSize(10,10)
patch=1,EE,21F70F94,extended,26108090 // addiu s0, -0x7F70   ; s0 = 0x003D8090
patch=1,EE,21F70F98,extended,02002025 // move a0, s0
patch=1,EE,21F70F9C,extended,3405000A // li a1, 10
patch=1,EE,21F70FA0,extended,0C0B5128 // jal SetDrawSize
patch=1,EE,21F70FA4,extended,3406000A // li a2, 10  (delay)
// D58 SetClearance(9,10)
patch=1,EE,21F70FA8,extended,02002025 // move a0, s0
patch=1,EE,21F70FAC,extended,34050009 // li a1, 9
patch=1,EE,21F70FB0,extended,0C0B512C // jal SetClearance
